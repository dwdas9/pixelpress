<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PixelPress.Desktop.ViewModels"
        xmlns:shapes="using:Avalonia.Controls.Shapes"
        x:Class="PixelPress.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="PixelPress"
        Width="1440" Height="900"
        MinWidth="960" MinHeight="600"
        Background="{DynamicResource CanvasBrush}"
        WindowStartupLocation="CenterScreen">

    <!--
      Workspace layout (M11). Replaces the scrolling wizard with a persistent
      three-column workspace: queue | viewport | inspector, toolbar above and
      status bar below. The panes never unmount — the workflow stage
      (ADR-0006) drives overlays inside the viewport instead of swapping whole
      screens, so the inspector stays reachable at every stage.
      All colour lives in Styles/AppStyles.axaml.
    -->

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ==================== Menu bar ==================== -->
        <!--
          Every item here is a real command bound to real view-model state.
          Nothing is stubbed: a greyed-out menu that never lights up is worse
          than an absent one.
        -->
        <Menu Grid.Row="0"
              Background="{DynamicResource CardBrush}"
              BorderBrush="{DynamicResource HairlineBrush}"
              BorderThickness="0,0,0,1">

            <MenuItem Header="_File">
                <MenuItem Header="Add _Files…"
                          InputGesture="Ctrl+O"
                          Click="OnAddFilesClick" />
                <MenuItem Header="Add F_older…"
                          InputGesture="Ctrl+Shift+O"
                          Click="OnAddFolderClick" />
                <Separator />
                <MenuItem Header="_Optimize Batch"
                          InputGesture="Ctrl+Enter"
                          IsEnabled="{Binding CanOptimize}"
                          Command="{Binding OptimizeCommand}" />
                <MenuItem Header="_Stop"
                          IsEnabled="{Binding IsRunning}"
                          Command="{Binding CancelRunCommand}" />
                <Separator />
                <MenuItem Header="Open Output Folder"
                          Command="{Binding OpenOutputFolderCommand}" />
                <MenuItem Header="Change Output Folder…"
                          IsEnabled="{Binding ShowOutputFolderControl}"
                          Click="OnChangeOutputFolderClick" />
                <Separator />
                <MenuItem Header="E_xit" Click="OnExitClick" />
            </MenuItem>

            <MenuItem Header="_Edit">
                <MenuItem Header="_Remove From Queue"
                          InputGesture="Delete"
                          Command="{Binding RemoveSelectedCommand}" />
                <MenuItem Header="_Clear Queue"
                          IsEnabled="{Binding HasPlan}"
                          Command="{Binding StartOverCommand}" />
                <Separator />
                <MenuItem Header="Show in _File Manager"
                          Command="{Binding ShowSelectedInFolderCommand}" />
            </MenuItem>

            <MenuItem Header="_View">
                <!-- Key names must be Avalonia Key enum members, not the
                     glyphs on the keycaps: OemPlus/OemMinus/D0, never
                     Plus/Minus/0. KeyGesture.Parse throws at XAML load
                     otherwise, taking the whole window down at startup. -->
                <MenuItem Header="Zoom _In"
                          InputGesture="Ctrl+OemPlus"
                          Command="{Binding ZoomInCommand}" />
                <MenuItem Header="Zoom _Out"
                          InputGesture="Ctrl+OemMinus"
                          Command="{Binding ZoomOutCommand}" />
                <MenuItem Header="_Fit to Window"
                          InputGesture="Ctrl+D0"
                          Command="{Binding ResetZoomCommand}" />
                <Separator />
                <MenuItem Header="Show _All Files"
                          Command="{Binding ShowAllFilesCommand}" />
                <MenuItem Header="Show Only _Failed"
                          Command="{Binding ShowFailedFilesCommand}" />
                <Separator />
                <MenuItem Header="Toggle _Theme" Click="OnToggleThemeClick" />
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_Supported Formats" Click="OnSupportedFormatsClick" />
            </MenuItem>
        </Menu>

        <!-- ==================== Toolbar ==================== -->
        <Border Grid.Row="1"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                    <Button Classes="subtle"
                            Content="＋  Add files"
                            HotKey="Ctrl+O"
                            ToolTip.Tip="Add images to the queue (Ctrl+O)"
                            IsEnabled="{Binding !IsRunning}"
                            Click="OnAddFilesClick" />
                    <Button Classes="subtle"
                            Content="🗀  Add folder"
                            IsEnabled="{Binding !IsRunning}"
                            Click="OnAddFolderClick" />
                    <Button Classes="ghost"
                            Content="Clear"
                            IsEnabled="{Binding HasPlan}"
                            Command="{Binding StartOverCommand}" />
                </StackPanel>

                <Rectangle Grid.Column="1"
                           Width="1" Margin="10,2"
                           Fill="{DynamicResource HairlineBrush}" />

                <!-- Start and Stop swap on IsRunning, so the primary slot
                     always holds the one legal batch action. -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
                    <Button Classes="primary"
                            Content="{Binding OptimizeButtonLabel}"
                            HotKey="Ctrl+Return"
                            ToolTip.Tip="Run the batch (Ctrl+Enter)"
                            IsVisible="{Binding !IsRunning}"
                            IsEnabled="{Binding CanOptimize}"
                            Command="{Binding OptimizeCommand}" />
                    <Button Classes="primary"
                            Content="{Binding CancelButtonLabel}"
                            IsVisible="{Binding IsRunning}"
                            IsEnabled="{Binding CanCancel}"
                            Command="{Binding CancelRunCommand}" />
                </StackPanel>

                <Button Grid.Column="4"
                        x:Name="ThemeToggle"
                        Classes="ghost"
                        Content="🌙  Dark"
                        Margin="8,0,0,0"
                        Click="OnToggleThemeClick" />
            </Grid>
        </Border>

        <!-- ==================== Three columns ==================== -->
        <Grid Grid.Row="2" ColumnDefinitions="300,Auto,*,Auto,340">

            <!-- ===== Left: asset queue ===== -->
            <Border Grid.Column="0"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource HairlineBrush}"
                    BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*,Auto">

                    <StackPanel Grid.Row="0" Margin="14,12,14,8" Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Classes="railHeading"
                                       Text="QUEUE"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Classes="caption"
                                       VerticalAlignment="Center"
                                       Text="{Binding ImageCount, StringFormat='{}{0} items'}" />
                        </Grid>

                        <!-- Filters earn their keep after a run with failures,
                             when the three bad files are buried among ninety-
                             seven good ones. -->
                        <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding HasPlan}">
                            <RadioButton Classes="chip"
                                         GroupName="QueueFilter"
                                         Content="All"
                                         IsChecked="{Binding SelectedQueueFilter,
                                                     Converter={x:Static vm:EnumMatchConverter.Instance},
                                                     ConverterParameter={x:Static vm:QueueFilter.All}}" />
                            <RadioButton Classes="chip"
                                         GroupName="QueueFilter"
                                         Content="{Binding OptimizedCount, StringFormat='Done ({0})'}"
                                         IsChecked="{Binding SelectedQueueFilter,
                                                     Converter={x:Static vm:EnumMatchConverter.Instance},
                                                     ConverterParameter={x:Static vm:QueueFilter.Optimized}}" />
                            <RadioButton Classes="chip"
                                         GroupName="QueueFilter"
                                         Content="{Binding FailedItemCount, StringFormat='Failed ({0})'}"
                                         IsChecked="{Binding SelectedQueueFilter,
                                                     Converter={x:Static vm:EnumMatchConverter.Instance},
                                                     ConverterParameter={x:Static vm:QueueFilter.Failed}}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Selecting a row drives the viewport and the statistics
                         overlay; everything else on screen is whole-batch. -->
                    <ListBox Grid.Row="1"
                             x:Name="QueueList"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="6,0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemsSource="{Binding VisibleQueueRows}"
                             SelectedItem="{Binding SelectedPlanItem}">

                        <!-- Right-clicking a row acts on that row, so the menu
                             is bound to the window's view model rather than the
                             row's, and every command works off SelectedPlanItem.
                             OnQueueRightClick selects the row under the cursor
                             first, so right-click-without-left-click behaves. -->
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Remove From Queue"
                                          Command="{Binding RemoveSelectedCommand}" />
                                <Separator />
                                <MenuItem Header="Show in File Manager"
                                          Command="{Binding ShowSelectedInFolderCommand}" />
                            </ContextMenu>
                        </ListBox.ContextMenu>

                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PlanItemRow">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      Height="46"
                                      Margin="0,1"
                                      ToolTip.Tip="{Binding SourcePath}">

                                    <!-- The badge is the fallback, not the
                                         placeholder: AVIF and RAW have no
                                         platform decoder, so their rows keep it
                                         for good. -->
                                    <Panel Grid.Column="0" Width="34" Height="34" VerticalAlignment="Center">
                                        <Border CornerRadius="6"
                                                Background="{DynamicResource AccentSoftBrush}">
                                            <TextBlock Text="{Binding OutputFormatName}"
                                                       FontSize="9"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <Border CornerRadius="6" ClipToBounds="True">
                                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                                        </Border>
                                    </Panel>

                                    <StackPanel Grid.Column="1"
                                                Margin="10,0,8,0"
                                                VerticalAlignment="Center"
                                                Spacing="1">
                                        <TextBlock Text="{Binding FileName}"
                                                   FontSize="13"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding FormatSummary}"
                                                   Classes="caption"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                                Orientation="Horizontal"
                                                Spacing="6"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding SizeText}" Classes="caption" />
                                        <TextBlock Text="✓"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource SuccessBrush}"
                                                   IsVisible="{Binding IsOptimized}" />
                                        <!-- Kept as-is: encoded fine, but no
                                             smaller, so the original stands. -->
                                        <TextBlock Text="="
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   IsVisible="{Binding IsUnchanged}"
                                                   ToolTip.Tip="Already as small as this quality setting can make it — the original was kept." />
                                        <TextBlock Text="!"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource DangerBrush}"
                                                   IsVisible="{Binding IsFailed}"
                                                   ToolTip.Tip="{Binding ErrorMessage}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="2"
                               Classes="caption"
                               Margin="14,8"
                               IsVisible="{Binding HasMoreItems}"
                               Text="{Binding MoreItemsNote}" />
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4"
                          Background="Transparent"
                          ResizeDirection="Columns" />

            <!-- ===== Center: viewport ===== -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto">

                <!-- Which image, and how exact its numbers are -->
                <Border Grid.Row="0"
                        Padding="16,10"
                        IsVisible="{Binding HasPreview}"
                        BorderBrush="{DynamicResource HairlineBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="1">
                            <TextBlock Text="{Binding PreviewFileName}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding PreviewDimensionsText}" Classes="caption" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding ZoomLabel}"
                                       Classes="caption"
                                       VerticalAlignment="Center"
                                       Width="42"
                                       TextAlignment="Right" />
                            <Slider x:Name="ZoomSlider"
                                    Width="120"
                                    Minimum="0.25" Maximum="4"
                                    VerticalAlignment="Center"
                                    Value="{Binding ZoomFactor}" />
                            <Button Classes="ghost"
                                    Content="Fit"
                                    Command="{Binding ResetZoomCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- The comparison surface. Both panes render the same image
                     box; the "after" pane is clipped to a band whose width the
                     code-behind drives from the handle (Phase 2). -->
                <Border Grid.Row="1" Classes="pane" Margin="16"
                        PointerWheelChanged="OnViewportWheel">
                    <Panel>
                        <Panel.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Zoom In" Command="{Binding ZoomInCommand}" />
                                <MenuItem Header="Zoom Out" Command="{Binding ZoomOutCommand}" />
                                <MenuItem Header="Fit to Window" Command="{Binding ResetZoomCommand}" />
                                <Separator />
                                <MenuItem Header="Remove From Queue"
                                          Command="{Binding RemoveSelectedCommand}" />
                                <MenuItem Header="Show in File Manager"
                                          Command="{Binding ShowSelectedInFolderCommand}" />
                            </ContextMenu>
                        </Panel.ContextMenu>

                        <ScrollViewer x:Name="CompareScroller"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      IsVisible="{Binding HasPreview}">
                            <LayoutTransformControl HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                <LayoutTransformControl.LayoutTransform>
                                    <ScaleTransform ScaleX="{Binding ZoomFactor}"
                                                    ScaleY="{Binding ZoomFactor}" />
                                </LayoutTransformControl.LayoutTransform>

                                <Panel x:Name="CompareHost" MinWidth="240" MinHeight="240">

                                    <Image Source="{Binding OriginalPreviewImage}" Stretch="Uniform" />

                                    <!-- AfterClip.Width is set imperatively on drag;
                                         the inner Image keeps the host's full box so
                                         clipping reveals rather than squeezes it. -->
                                    <Border x:Name="AfterClip"
                                            HorizontalAlignment="Left"
                                            ClipToBounds="True">
                                        <Image Source="{Binding OutputPreviewImage}"
                                               Stretch="Uniform"
                                               HorizontalAlignment="Left"
                                               Width="{Binding #CompareHost.Bounds.Width}"
                                               Height="{Binding #CompareHost.Bounds.Height}" />
                                    </Border>

                                    <Canvas x:Name="HandleLayer" Background="Transparent">
                                        <shapes:Rectangle x:Name="DividerLine"
                                                          Width="2"
                                                          Height="{Binding #CompareHost.Bounds.Height}"
                                                          Fill="White"
                                                          Opacity="0.9" />
                                        <Border x:Name="DividerHandle"
                                                Width="28" Height="28"
                                                CornerRadius="14"
                                                Background="White"
                                                BoxShadow="0 2 8 0 #40000000"
                                                Cursor="SizeWestEast">
                                            <TextBlock Text="⇄"
                                                       Foreground="#0F172A"
                                                       FontSize="13"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </Canvas>
                                </Panel>
                            </LayoutTransformControl>
                        </ScrollViewer>

                        <!-- Floating pane labels -->
                        <Border IsVisible="{Binding HasPreview}"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                Margin="12" Padding="8,4" CornerRadius="6"
                                Background="#99000000">
                            <TextBlock Text="ORIGINAL" FontSize="10" FontWeight="SemiBold" Foreground="White" />
                        </Border>
                        <Border IsVisible="{Binding HasPreview}"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="12" Padding="8,4" CornerRadius="6"
                                Background="#99000000">
                            <TextBlock Text="OPTIMIZED" FontSize="10" FontWeight="SemiBold" Foreground="White" />
                        </Border>

                        <!-- Statistics overlay. PreviewAccuracyNote says whether
                             these bytes were measured or estimated — ADR-0006
                             forbids conflating the two. -->
                        <Border IsVisible="{Binding HasPreview}"
                                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                Margin="16" Padding="18,12" CornerRadius="12"
                                Background="#CC000000">
                            <StackPanel Orientation="Horizontal" Spacing="22">
                                <StackPanel Spacing="1">
                                    <TextBlock Text="Original" FontSize="10" Foreground="#94A3B8" />
                                    <TextBlock Text="{Binding PreviewOriginalSizeText}"
                                               FontSize="15" FontWeight="SemiBold" Foreground="White" />
                                </StackPanel>
                                <StackPanel Spacing="1">
                                    <TextBlock Text="Optimized" FontSize="10" Foreground="#94A3B8" />
                                    <TextBlock Text="{Binding PreviewOutputSizeText}"
                                               FontSize="15" FontWeight="SemiBold" Foreground="White" />
                                </StackPanel>
                                <StackPanel Spacing="1">
                                    <TextBlock Text="{Binding PreviewAccuracyNote}"
                                               FontSize="10" Foreground="#94A3B8" />
                                    <TextBlock Text="{Binding PreviewSavingsText}"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="{DynamicResource SuccessBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border IsVisible="{Binding IsPreviewBusy}"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="16" Padding="10,6" CornerRadius="8"
                                Background="#CC000000">
                            <TextBlock Text="Encoding…" FontSize="11" Foreground="White" />
                        </Border>

                        <!-- Encode succeeded, but no decoder here can show it -->
                        <Border IsVisible="{Binding HasOutputPreviewUnavailableNote}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                MaxWidth="360" Padding="16,12" CornerRadius="10"
                                Background="#CC000000">
                            <TextBlock Text="{Binding OutputPreviewUnavailableNote}"
                                       FontSize="12" Foreground="White"
                                       TextWrapping="Wrap" TextAlignment="Center" />
                        </Border>

                        <!-- Empty state / drop target -->
                        <Border x:Name="DropZoneInner"
                                IsVisible="{Binding ShowDropZone}"
                                Background="Transparent"
                                CornerRadius="10"
                                PointerPressed="OnDropZonePressed">
                            <Panel>
                                <shapes:Rectangle x:Name="DropOutline"
                                                  Margin="28"
                                                  RadiusX="12" RadiusY="12"
                                                  Stroke="{DynamicResource HairlineBrush}"
                                                  StrokeThickness="2"
                                                  StrokeDashArray="6,4"
                                                  Fill="Transparent" />
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="8">
                                    <TextBlock Text="Drop images here"
                                               Classes="h2"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding SupportedInputSummary}"
                                               Classes="caption"
                                               MaxWidth="420"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                    <Button Classes="subtle"
                                            Content="Choose files…"
                                            HorizontalAlignment="Center"
                                            Margin="0,8,0,0"
                                            Click="OnAddFilesClick" />
                                </StackPanel>
                            </Panel>
                        </Border>

                        <Border IsVisible="{Binding IsPlanning}"
                                Background="{DynamicResource PreviewBackdropBrush}">
                            <TextBlock Text="Reading files…"
                                       Classes="body secondary"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <!-- Summary sits over the viewport rather than owning a
                             screen, so the queue and inspector stay visible and
                             a second pass needs no back-navigation. -->
                        <Border IsVisible="{Binding HasSummary}"
                                Background="{DynamicResource PreviewBackdropBrush}">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        MaxWidth="480"
                                        Spacing="10">
                                <TextBlock Text="{Binding SummaryHeadline}"
                                           Classes="h2"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center" />

                                <!-- SummarySavings is now always a short figure
                                     ("58% smaller", "No change"), so it fits the
                                     36px stat. Wrapping stays as a backstop. -->
                                <TextBlock Text="{Binding SummarySavings}"
                                           Classes="stat"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center" />

                                <!-- The sentence that used to be crammed into
                                     the stat, and clipped. -->
                                <TextBlock Text="{Binding SummarySavingsNote}"
                                           IsVisible="{Binding HasSummarySavingsNote}"
                                           Classes="caption"
                                           MaxWidth="420"
                                           Margin="0,2,0,6"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center" />

                                <TextBlock Classes="caption"
                                           HorizontalAlignment="Center"
                                           Text="{Binding SummaryOriginalSizeText, StringFormat='{}{0} before'}" />
                                <TextBlock Classes="caption"
                                           HorizontalAlignment="Center"
                                           Text="{Binding SummaryFinalSizeText, StringFormat='{}{0} after'}" />

                                <ItemsControl ItemsSource="{Binding FailureMessages}"
                                              IsVisible="{Binding HasFailures}"
                                              Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <TextBlock Text="{Binding}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource DangerBrush}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            HorizontalAlignment="Center"
                                            Margin="0,8,0,0">
                                    <Button Classes="subtle"
                                            Content="Open output folder"
                                            Click="OnOpenOutputFolderClick" />
                                    <Button Classes="primary"
                                            Content="Start over"
                                            Command="{Binding StartOverCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Panel>
                </Border>

                <!-- Batch-level warnings: fallbacks, renames, skips -->
                <StackPanel Grid.Row="2" Margin="16,0,16,12" Spacing="3">
                    <TextBlock Classes="caption"
                               IsVisible="{Binding HasFormatFallbacks}"
                               Text="{Binding FallbackSummary}"
                               TextWrapping="Wrap" />
                    <TextBlock Classes="caption"
                               IsVisible="{Binding HasRenames}"
                               Text="{Binding RenamedSummary}"
                               TextWrapping="Wrap" />
                    <ItemsControl ItemsSource="{Binding SkippedGroups}"
                                  IsVisible="{Binding HasSkippedFiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{Binding}" Classes="caption" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4"
                          Background="Transparent"
                          ResizeDirection="Columns" />

            <!-- ===== Right: inspector ===== -->
            <Border Grid.Column="4"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource HairlineBrush}"
                    BorderThickness="1,0,0,0">
                <ScrollViewer>
                    <StackPanel Margin="14" Spacing="6">

                        <TextBlock Classes="railHeading" Text="INSPECTOR" Margin="2,4,2,6" />

                        <Expander Header="Format" IsExpanded="True">
                            <StackPanel Spacing="8" Margin="0,6,0,2">
                                <ComboBox HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding AvailableTargetFormats}"
                                          SelectedItem="{Binding SelectedTargetFormatOption}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:MainWindowViewModel+FormatOption">
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Classes="caption"
                                           TextWrapping="Wrap"
                                           Text="{Binding SupportedInputSummary}" />
                            </StackPanel>
                        </Expander>

                        <Expander Header="Quality" IsExpanded="True">
                            <StackPanel Spacing="6" Margin="0,6,0,2">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Classes="caption"
                                               Text="{Binding QualityLabel}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Quality}"
                                               FontWeight="SemiBold"
                                               FontSize="13" />
                                </Grid>
                                <Slider Minimum="1" Maximum="100"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding Quality}" />
                            </StackPanel>
                        </Expander>

                        <Expander Header="Resize" IsExpanded="False">
                            <StackPanel Spacing="8" Margin="0,6,0,2">
                                <CheckBox Content="Limit longest edge"
                                          IsChecked="{Binding ResizeEnabled}" />
                                <NumericUpDown Minimum="16" Maximum="20000"
                                               Increment="64"
                                               FormatString="0"
                                               IsEnabled="{Binding ResizeEnabled}"
                                               Value="{Binding ResizeMaxDimensionPixels}" />
                                <TextBlock Classes="caption"
                                           TextWrapping="Wrap"
                                           Text="Images smaller than this keep their original size." />
                            </StackPanel>
                        </Expander>

                        <Expander Header="Metadata" IsExpanded="False">
                            <StackPanel Spacing="8" Margin="0,6,0,2">
                                <CheckBox Content="Strip metadata"
                                          IsChecked="{Binding StripMetadata}" />
                                <TextBlock Classes="caption"
                                           TextWrapping="Wrap"
                                           Text="Removes EXIF, GPS and colour-profile tags." />
                            </StackPanel>
                        </Expander>

                        <Expander Header="Output" IsExpanded="True">
                            <StackPanel Spacing="8" Margin="0,6,0,2">
                                <CheckBox Content="Overwrite originals"
                                          IsChecked="{Binding OverwriteOriginals}" />
                                <StackPanel Spacing="6" IsVisible="{Binding ShowOutputFolderControl}">
                                    <TextBlock Text="{Binding OutputDirectory}"
                                               Classes="caption"
                                               TextWrapping="Wrap" />
                                    <Button Classes="subtle"
                                            Content="Change folder…"
                                            HorizontalAlignment="Stretch"
                                            Click="OnChangeOutputFolderClick" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <!-- Whole-batch estimate. Distinct from the viewport
                             overlay, which reports one exactly-encoded image. -->
                        <Border Classes="reservedSlot" Margin="0,8,0,0" IsVisible="{Binding HasPlan}">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="railHeading" Text="BATCH ESTIMATE" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="Original" Classes="caption" />
                                    <TextBlock Grid.Column="1" Text="{Binding OriginalSizeText}" FontSize="12" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="Estimated" Classes="caption" />
                                    <TextBlock Grid.Column="1" Text="{Binding EstimatedSizeText}" FontSize="12" />
                                </Grid>
                                <TextBlock Text="{Binding EstimatedSavingsSummary}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ==================== Status bar ==================== -->
        <Border Grid.Row="3"
                Background="{DynamicResource StatusBarBrush}"
                BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,6">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusBarText}"
                           Classes="caption"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Column="1"
                           Margin="14,0"
                           Classes="caption"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           IsVisible="{Binding HasStatusMessage}"
                           Foreground="{DynamicResource DangerBrush}"
                           Text="{Binding StatusMessage}" />

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="12"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsRunning}">
                    <TextBlock Classes="caption"
                               MaxWidth="280"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding ProgressLabel}" />
                    <TextBlock Classes="caption"
                               IsVisible="{Binding HasRunMetrics}"
                               Text="{Binding ThroughputText}" />
                    <TextBlock Classes="caption"
                               IsVisible="{Binding HasRunMetrics}"
                               Text="{Binding EtaText, StringFormat='{}{0} left'}" />
                </StackPanel>

                <ProgressBar Grid.Column="3"
                             Classes="slim"
                             Width="200"
                             VerticalAlignment="Center"
                             IsVisible="{Binding IsRunning}"
                             Minimum="0" Maximum="100"
                             Value="{Binding ProgressPercent}" />
            </Grid>
        </Border>
    </Grid>
</Window>

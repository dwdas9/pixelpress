<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PixelPress.Desktop.ViewModels"
        x:Class="PixelPress.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="PixelPress"
        Width="1180" Height="800"
        MinWidth="980" MinHeight="660"
        Background="{DynamicResource CanvasBrush}"
        WindowStartupLocation="CenterScreen">

    <!--
      Three persistent zones: header, content stage (the five workflow
      states, one visible at a time), and status bar. All visual
      language lives in Styles/AppStyles.axaml; theming is instant via
      DynamicResource + theme dictionaries.
    -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ============ Header ============ -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="32,20,32,16">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                <Border CornerRadius="10" Width="38" Height="38">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#6366F1" Offset="0" />
                            <GradientStop Color="#8B5CF6" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="⬇" FontSize="19" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="PixelPress" FontSize="17" FontWeight="Bold" />
                    <TextBlock Classes="caption" Text="Optimize images — private, offline" />
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="2" Classes="subtle"
                    Name="ThemeToggle"
                    Content="🌙  Dark"
                    Click="OnToggleThemeClick"
                    VerticalAlignment="Center" />
        </Grid>

        <!-- ============ Content stage ============ -->
        <Grid Grid.Row="1" Margin="32,0,32,20">

            <!-- State 1: awaiting input -->
            <Grid RowDefinitions="*,Auto" IsVisible="{Binding ShowDropZone}">

                <Border Grid.Row="0" Classes="card" Padding="12">
                    <Border Name="DropZoneInner"
                            DragDrop.AllowDrop="True"
                            Background="Transparent"
                            CornerRadius="12"
                            Cursor="Hand"
                            PointerPressed="OnDropZonePressed">
                        <Grid>
                            <Rectangle Name="DropOutline"
                                       Stroke="{DynamicResource HairlineBrush}"
                                       StrokeThickness="2"
                                       StrokeDashArray="6,4"
                                       RadiusX="12" RadiusY="12"
                                       Fill="Transparent" />
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Spacing="14" Margin="24">
                                <Border Background="{DynamicResource AccentSoftBrush}"
                                        CornerRadius="32" Width="64" Height="64"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="⬆" FontSize="26"
                                               Foreground="{DynamicResource AccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Classes="h2"
                                           Text="Drop images or folders here"
                                           HorizontalAlignment="Center" />
                                <TextBlock Classes="body secondary"
                                           Text="Shrink photos and screenshots without losing what matters — everything stays on your computer."
                                           TextWrapping="Wrap" MaxWidth="420"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            HorizontalAlignment="Center">
                                    <Button Classes="subtle" Content="Browse files…"
                                            Click="OnDropZonePressedButton" />
                                    <Button Classes="subtle" Content="Choose a folder…"
                                            Click="OnBrowseFolderClick" />
                                </StackPanel>
                                <TextBlock Classes="caption"
                                           Text="{Binding SupportedInputSummary}"
                                           TextWrapping="Wrap" MaxWidth="440"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Border>

                <StackPanel Grid.Row="1" Margin="0,18,0,0" Spacing="10">
                    <Border Classes="card" Padding="22,16" MaxWidth="580"
                            HorizontalAlignment="Center">
                        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="1">
                                <TextBlock Classes="caption" FontWeight="SemiBold" Text="OUTPUT QUALITY" />
                                <TextBlock Classes="caption" Text="JPEG · WebP · AVIF · JPEG XL" />
                            </StackPanel>
                            <Slider Grid.Column="1" Margin="18,0" VerticalAlignment="Center"
                                    Minimum="1" Maximum="100"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    Value="{Binding Quality}" />
                            <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                        MinWidth="88" Spacing="0">
                                <TextBlock Classes="h2" TextAlignment="Right"
                                           Text="{Binding Quality}" />
                                <TextBlock Classes="caption" TextAlignment="Right"
                                           Text="{Binding QualityLabel}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock Classes="caption"
                               Foreground="{DynamicResource DangerBrush}"
                               Text="{Binding StatusMessage}"
                               HorizontalAlignment="Center"
                               IsVisible="{Binding HasStatusMessage}" />
                </StackPanel>
            </Grid>

            <!-- State 2: planning -->
            <StackPanel IsVisible="{Binding IsPlanning}"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Spacing="14">
                <ProgressBar Classes="slim" IsIndeterminate="True" Width="220" />
                <TextBlock Classes="body secondary"
                           Text="Looking through your files…"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!--
              State 3: the compression studio (M10, ADR-0006 §5).
              Preview area (left) + controls rail (right) + a statistics
              strip spanning both. The strip reports the selected image and
              the whole batch side by side but never merges them: one is an
              encode, the other a heuristic.
            -->
            <Grid RowDefinitions="*,Auto,Auto" ColumnDefinitions="*,332"
                  IsVisible="{Binding HasPlan}">

                <!-- ======== Preview area ======== -->
                <Border Grid.Row="0" Grid.Column="0" Classes="card"
                        Padding="18" Margin="0,0,14,0">
                    <Grid RowDefinitions="Auto,*,Auto,Auto">

                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="2,0,2,12">
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Classes="h2" Text="{Binding PreviewFileName}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Classes="caption" Text="{Binding PreviewDimensionsText}" />
                            </StackPanel>
                            <ProgressBar Grid.Column="1" Classes="slim" Width="72"
                                         IsIndeterminate="True"
                                         VerticalAlignment="Center"
                                         IsVisible="{Binding IsPreviewBusy}" />
                        </Grid>

                        <Grid Grid.Row="1" ColumnDefinitions="*,14,*">

                            <Grid Grid.Column="0" RowDefinitions="Auto,*">
                                <TextBlock Grid.Row="0" Classes="paneLabel" Text="ORIGINAL"
                                           Margin="2,0,0,6" />
                                <Border Grid.Row="1" Classes="pane">
                                    <Grid Name="OriginalPane">
                                        <!--
                                          The image is sized to its pane, not to
                                          its own pixels, so zoom 1.0 means "fit".
                                          Binding to the pane's Bounds (set by the
                                          column) rather than the ScrollViewer's
                                          viewport keeps measure out of a loop.
                                        -->
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto">
                                            <LayoutTransformControl>
                                                <LayoutTransformControl.LayoutTransform>
                                                    <ScaleTransform ScaleX="{Binding ZoomFactor}"
                                                                    ScaleY="{Binding ZoomFactor}" />
                                                </LayoutTransformControl.LayoutTransform>
                                                <Image Source="{Binding OriginalPreviewImage}"
                                                       Stretch="Uniform"
                                                       Width="{Binding #OriginalPane.Bounds.Width}"
                                                       Height="{Binding #OriginalPane.Bounds.Height}" />
                                            </LayoutTransformControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Grid Grid.Column="2" RowDefinitions="Auto,*">
                                <TextBlock Grid.Row="0" Classes="paneLabel" Text="OPTIMIZED"
                                           Margin="2,0,0,6" />
                                <Border Grid.Row="1" Classes="pane">
                                    <Grid Name="OutputPane">
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Auto">
                                            <LayoutTransformControl>
                                                <LayoutTransformControl.LayoutTransform>
                                                    <ScaleTransform ScaleX="{Binding ZoomFactor}"
                                                                    ScaleY="{Binding ZoomFactor}" />
                                                </LayoutTransformControl.LayoutTransform>
                                                <Image Source="{Binding OutputPreviewImage}"
                                                       Stretch="Uniform"
                                                       Width="{Binding #OutputPane.Bounds.Width}"
                                                       Height="{Binding #OutputPane.Bounds.Height}" />
                                            </LayoutTransformControl>
                                        </ScrollViewer>
                                        <TextBlock Classes="caption"
                                                   Text="{Binding OutputPreviewUnavailableNote}"
                                                   IsVisible="{Binding HasOutputPreviewUnavailableNote}"
                                                   TextWrapping="Wrap" MaxWidth="240"
                                                   TextAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto,Auto" Margin="2,14,2,0">
                            <TextBlock Grid.Column="0" Classes="railHeading" Text="ZOOM"
                                       VerticalAlignment="Center" />
                            <Slider Grid.Column="1" Margin="14,0" VerticalAlignment="Center"
                                    Minimum="1" Maximum="4"
                                    TickFrequency="0.25" IsSnapToTickEnabled="True"
                                    Value="{Binding ZoomFactor}" />
                            <TextBlock Grid.Column="2" Classes="body secondary"
                                       MinWidth="48" TextAlignment="Right"
                                       Text="{Binding ZoomLabel}" VerticalAlignment="Center" />
                            <Button Grid.Column="3" Classes="ghost" Margin="8,0,0,0"
                                    Content="Fit" Command="{Binding ResetZoomCommand}" />
                        </Grid>

                        <StackPanel Grid.Row="3" Spacing="6" Margin="0,12,0,0">
                            <Border Height="1" Background="{DynamicResource HairlineBrush}" />
                            <ListBox Classes="filmstrip" Margin="0,6,0,0" MaxHeight="62"
                                     ItemsSource="{Binding PlanItemRows}"
                                     SelectedItem="{Binding SelectedPlanItem}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Classes="filmstripCard">
                                            <StackPanel Spacing="1" MaxWidth="160">
                                                <TextBlock Classes="body" FontSize="13"
                                                           Text="{Binding FileName}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Classes="caption"
                                                           Text="{Binding FormatSummary}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <TextBlock Classes="caption" Text="{Binding MoreItemsNote}"
                                       IsVisible="{Binding HasMoreItems}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ======== Controls rail ======== -->
                <Border Grid.Row="0" Grid.Column="1" Classes="card" Padding="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="20">

                            <StackPanel Spacing="8">
                                <TextBlock Classes="railHeading" Text="QUALITY" />
                                <Grid ColumnDefinitions="Auto,*">
                                    <TextBlock Grid.Column="0" Classes="h2" Text="{Binding Quality}" />
                                    <TextBlock Grid.Column="1" Classes="body secondary"
                                               TextAlignment="Right" VerticalAlignment="Bottom"
                                               Text="{Binding QualityLabel}" />
                                </Grid>
                                <Slider Minimum="1" Maximum="100"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        Value="{Binding Quality}" />
                                <TextBlock Classes="caption" TextWrapping="Wrap"
                                           Text="Applies to JPEG, WebP, AVIF and JPEG XL. PNG and BMP are lossless and ignore it." />
                            </StackPanel>

                            <Border Height="1" Background="{DynamicResource HairlineBrush}" />

                            <StackPanel Spacing="8">
                                <TextBlock Classes="railHeading" Text="CONVERT TO" />
                                <ListBox Classes="presets"
                                         ItemsSource="{Binding AvailableTargetFormats}"
                                         SelectedItem="{Binding SelectedTargetFormatOption}">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Classes="presetCard" Padding="10,7">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="12" />
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>

                            <Border Height="1" Background="{DynamicResource HairlineBrush}" />

                            <StackPanel Spacing="10">
                                <TextBlock Classes="railHeading" Text="RESIZE" />
                                <CheckBox Content="Shrink images larger than"
                                          IsChecked="{Binding ResizeEnabled}" />
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="26,0,0,0">
                                    <NumericUpDown Value="{Binding ResizeMaxDimensionPixels}"
                                                   Minimum="1" Maximum="20000" Increment="64"
                                                   FormatString="0" Width="128"
                                                   IsEnabled="{Binding ResizeEnabled}" />
                                    <TextBlock Classes="body secondary" Text="px"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="{DynamicResource HairlineBrush}" />

                            <StackPanel Spacing="8">
                                <TextBlock Classes="railHeading" Text="METADATA" />
                                <CheckBox Content="Remove EXIF, location and camera data"
                                          IsChecked="{Binding StripMetadata}" />
                            </StackPanel>

                            <Border Height="1" Background="{DynamicResource HairlineBrush}" />

                            <StackPanel Spacing="8">
                                <TextBlock Classes="railHeading" Text="OUTPUT" />
                                <CheckBox Content="Overwrite the original files"
                                          IsChecked="{Binding OverwriteOriginals}" />
                                <TextBlock Classes="caption" Margin="26,0,0,0" TextWrapping="Wrap"
                                           Foreground="{DynamicResource DangerBrush}"
                                           Text="Replaces original files — cannot be undone."
                                           IsVisible="{Binding OverwriteOriginals}" />
                                <StackPanel Spacing="6" IsVisible="{Binding ShowOutputFolderControl}">
                                    <TextBlock Classes="caption" TextWrapping="Wrap"
                                               Text="{Binding OutputDirectory}" />
                                    <Button Classes="subtle" Content="Change output folder…"
                                            Click="OnChangeOutputFolderClick"
                                            HorizontalAlignment="Left" />
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="{DynamicResource HairlineBrush}" />

                            <!--
                              Deliberately empty. ADR-0006 §5 reserves this slot so
                              a future per-codec settings section drops in here
                              without another re-layout of the studio.
                            -->
                            <Border Classes="reservedSlot">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="railHeading" Text="PER-CODEC SETTINGS" />
                                    <TextBlock Classes="caption" TextWrapping="Wrap"
                                               Text="Reserved for a later release — chroma subsampling, encoder effort, progressive scan." />
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- ======== Compression statistics strip ======== -->
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                        Classes="card" Padding="24,18" Margin="0,14,0,0">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto,*">

                            <StackPanel Grid.Column="0" Spacing="3">
                                <TextBlock Classes="railHeading" Text="THIS IMAGE" />
                                <TextBlock Classes="statLarge" Text="{Binding PreviewSavingsText}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Classes="body secondary" Text="{Binding PreviewOriginalSizeText}" />
                                    <TextBlock Classes="body secondary" Text="→" />
                                    <TextBlock Classes="body" FontWeight="SemiBold"
                                               Text="{Binding PreviewOutputSizeText}" />
                                    <TextBlock Classes="caption" VerticalAlignment="Center"
                                               Text="{Binding PreviewAccuracyNote}" />
                                </StackPanel>
                            </StackPanel>

                            <Border Grid.Column="1" Width="1" Margin="28,2"
                                    Background="{DynamicResource HairlineBrush}" />

                            <StackPanel Grid.Column="2" Spacing="3">
                                <TextBlock Classes="railHeading" Text="WHOLE BATCH" />
                                <TextBlock Classes="statLarge" Text="{Binding EstimatedSavingsSummary}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Classes="body secondary" Text="{Binding OriginalSizeText}" />
                                    <TextBlock Classes="body secondary" Text="→" />
                                    <TextBlock Classes="body" FontWeight="SemiBold"
                                               Text="{Binding EstimatedSizeText}" />
                                    <TextBlock Classes="caption" Text="Estimated"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Classes="caption" TextWrapping="Wrap"
                                           Text="Resize is on — actual savings may exceed this estimate."
                                           IsVisible="{Binding ResizeEnabled}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="3">
                            <TextBlock Classes="caption"
                                       Text="{Binding FallbackSummary}"
                                       IsVisible="{Binding HasFormatFallbacks}" />
                            <TextBlock Classes="caption"
                                       Text="{Binding RenamedSummary}"
                                       IsVisible="{Binding HasRenames}" />
                            <ItemsControl ItemsSource="{Binding SkippedGroups}"
                                          IsVisible="{Binding HasSkippedFiles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Classes="caption" Text="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                            Margin="0,14,0,0" Spacing="6">
                    <Button Classes="primary"
                            Content="{Binding OptimizeButtonLabel}"
                            Command="{Binding OptimizeCommand}"
                            IsEnabled="{Binding CanOptimize}"
                            HorizontalAlignment="Stretch" />
                    <Button Classes="ghost"
                            Content="Start Over"
                            Command="{Binding StartOverCommand}"
                            HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- State 4: running -->
            <Grid RowDefinitions="*,Auto" IsVisible="{Binding IsRunning}">
                <Border Grid.Row="0" Classes="card" VerticalAlignment="Center">
                    <StackPanel Spacing="18">
                        <TextBlock Classes="h2" Text="Optimizing your images…"
                                   HorizontalAlignment="Center" />
                        <ProgressBar Classes="slim"
                                     Minimum="0" Maximum="100"
                                     Value="{Binding ProgressPercent}" />
                        <TextBlock Classes="caption"
                                   Text="{Binding ProgressLabel}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Button Grid.Row="1" Classes="ghost" Margin="0,16,0,0"
                        Content="{Binding CancelButtonLabel}"
                        Command="{Binding CancelRunCommand}"
                        IsEnabled="{Binding CanCancel}"
                        HorizontalAlignment="Center" />
            </Grid>

            <!-- State 5: completion summary -->
            <Grid RowDefinitions="*,Auto" IsVisible="{Binding HasSummary}">

                <Border Grid.Row="0" Classes="card" VerticalAlignment="Top">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="h1" Text="{Binding SummaryHeadline}" />
                            <TextBlock Classes="stat" Text="{Binding SummarySavings}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Classes="body secondary" Text="{Binding SummaryOriginalSizeText}" />
                                <TextBlock Classes="body secondary" Text="→" />
                                <TextBlock Classes="body" FontWeight="SemiBold" Text="{Binding SummaryFinalSizeText}" />
                            </StackPanel>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource HairlineBrush}" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Classes="body" FontWeight="Medium" Text="Saved to" />
                            <TextBlock Classes="body secondary"
                                       Text="{Binding OutputDirectory}"
                                       TextTrimming="CharacterEllipsis" MaxWidth="460" />
                        </StackPanel>

                        <StackPanel IsVisible="{Binding HasFailures}" Spacing="6">
                            <TextBlock Classes="body" FontWeight="Medium"
                                       Foreground="{DynamicResource DangerBrush}"
                                       Text="A few files couldn't be processed" />
                            <ItemsControl ItemsSource="{Binding FailureMessages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Classes="caption" Text="{Binding}" TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1" Margin="0,16,0,0" Spacing="8">
                    <Button Classes="primary"
                            Content="Open Output Folder"
                            Click="OnOpenOutputFolderClick"
                            HorizontalAlignment="Stretch" />
                    <Button Classes="ghost"
                            Content="Optimize More Images"
                            Command="{Binding StartOverCommand}"
                            HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

        </Grid>

        <!-- ============ Status bar ============ -->
        <Border Grid.Row="2" Background="{DynamicResource StatusBarBrush}"
                Padding="32,8">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Classes="caption" Text="{Binding StatusBarText}" />
                <TextBlock Grid.Column="1" Classes="caption" Text="PixelPress 0.1" />
            </Grid>
        </Border>

    </Grid>
</Window>

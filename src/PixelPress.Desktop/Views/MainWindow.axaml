<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PixelPress.Desktop.ViewModels"
        xmlns:views="using:PixelPress.Desktop.Views"
        xmlns:shapes="using:Avalonia.Controls.Shapes"
        x:Class="PixelPress.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="PixelPress"
        Width="1440" Height="900"
        MinWidth="960" MinHeight="600"
        Background="{DynamicResource CanvasBrush}"
        WindowStartupLocation="CenterScreen">

    <!--
      Workspace layout (M11). Replaces the scrolling wizard with a persistent
      three-column workspace: queue | viewport | inspector, toolbar above and
      status bar below. The panes never unmount — the workflow stage
      (ADR-0006) drives overlays inside the viewport instead of swapping whole
      screens, so the inspector stays reachable at every stage.
      All colour lives in Styles/AppStyles.axaml.
    -->

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ==================== Menu bar ==================== -->
        <!--
          Every item here is a real command bound to real view-model state.
          Nothing is stubbed: a greyed-out menu that never lights up is worse
          than an absent one.
        -->
        <Menu Grid.Row="0"
              Background="{DynamicResource CardBrush}"
              BorderBrush="{DynamicResource HairlineBrush}"
              BorderThickness="0,0,0,1">

            <MenuItem Header="_File">
                <MenuItem Header="Add _Files…"
                          InputGesture="Ctrl+O"
                          Click="OnAddFilesClick" />
                <MenuItem Header="Add F_older…"
                          InputGesture="Ctrl+Shift+O"
                          Click="OnAddFolderClick" />
                <Separator />
                <MenuItem Header="_Optimize Batch"
                          InputGesture="Ctrl+Enter"
                          IsEnabled="{Binding CanOptimize}"
                          Command="{Binding OptimizeCommand}" />
                <MenuItem Header="_Stop"
                          IsEnabled="{Binding IsRunning}"
                          Command="{Binding CancelRunCommand}" />
                <Separator />
                <MenuItem Header="Open Output Folder"
                          Command="{Binding OpenOutputFolderCommand}" />
                <MenuItem Header="Change Output Folder…"
                          IsEnabled="{Binding ShowOutputFolderControl}"
                          Click="OnChangeOutputFolderClick" />
                <Separator />
                <MenuItem Header="E_xit" Click="OnExitClick" />
            </MenuItem>

            <MenuItem Header="_Edit">
                <MenuItem Header="_Remove From Queue"
                          InputGesture="Delete"
                          Command="{Binding RemoveSelectedCommand}" />
                <MenuItem Header="_Clear Queue"
                          IsEnabled="{Binding HasPlan}"
                          Command="{Binding StartOverCommand}" />
                <Separator />
                <MenuItem Header="Show in _File Manager"
                          Command="{Binding ShowSelectedInFolderCommand}" />
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="Show _All Files"
                          Command="{Binding ShowAllFilesCommand}" />
                <MenuItem Header="Show Only _Failed"
                          Command="{Binding ShowFailedFilesCommand}" />
                <Separator />
                <!--
                  No InputGesture on these four. The toolbar buttons carry the
                  HotKeys, and a gesture here would have to be spelled the way
                  KeyGesture.Parse wants it ("Ctrl+D0", "Ctrl+OemPlus") — which is
                  both unreadable in a menu and the exact thing that crashed the
                  app at startup once already.
                -->
                <MenuItem Header="Zoom _In" IsEnabled="{Binding HasPreview}" Click="OnZoomInClick" />
                <MenuItem Header="Zoom _Out" IsEnabled="{Binding HasPreview}" Click="OnZoomOutClick" />
                <MenuItem Header="_Fit to Window" IsEnabled="{Binding HasPreview}" Click="OnFitToWindowClick" />
                <MenuItem Header="Actual _Size" IsEnabled="{Binding HasPreview}" Click="OnActualSizeClick" />
                <MenuItem Header="_Reset View" IsEnabled="{Binding HasPreview}" Click="OnResetViewClick" />
                <Separator />
                <MenuItem Header="Toggle _Theme" Click="OnToggleThemeClick" />
            </MenuItem>

            <!--
              About lives under Help rather than as its own top-level menu:
              that is where every Windows and Linux user looks for it, and on
              macOS the platform hoists it into the application menu anyway.

              There is deliberately no "Check for Updates" here yet. The app has
              no update channel, so the item could only ever be greyed out or
              lie, and a menu that never lights up is worse than an absent one.
            -->
            <MenuItem Header="_Help">
                <MenuItem Header="_User Guide" Click="OnUserGuideClick" />
                <MenuItem Header="_Keyboard Shortcuts" Click="OnKeyboardShortcutsClick" />
                <MenuItem Header="_Supported Formats" Click="OnSupportedFormatsClick" />
                <Separator />
                <MenuItem Header="_Project Website" Click="OnProjectWebsiteClick" />
                <MenuItem Header="_Report an Issue" Click="OnReportIssueClick" />
                <Separator />
                <MenuItem Header="_About PixelPress" Click="OnAboutClick" />
            </MenuItem>
        </Menu>

        <!-- ==================== Toolbar ==================== -->
        <Border Grid.Row="1"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                    <Button Classes="subtle"
                            HotKey="Ctrl+O"
                            ToolTip.Tip="Add images to the queue (Ctrl+O)"
                            IsEnabled="{Binding !IsRunning}"
                            Click="OnAddFilesClick">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <PathIcon Data="{StaticResource IconPlus}" />
                            <TextBlock Text="Add files" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="subtle"
                            ToolTip.Tip="Add every image in a folder"
                            IsEnabled="{Binding !IsRunning}"
                            Click="OnAddFolderClick">
                        <StackPanel Orientation="Horizontal" Spacing="7">
                            <PathIcon Data="{StaticResource IconFolder}" />
                            <TextBlock Text="Add folder" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Classes="ghost"
                            Content="Clear"
                            IsEnabled="{Binding HasPlan}"
                            Command="{Binding StartOverCommand}" />
                </StackPanel>

                <!-- Column 1 is the spacer that pushes the batch action right. -->

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <!-- Start and Stop swap on IsRunning, so the primary slot
                         always holds the one legal batch action. -->
                    <Button Classes="primary"
                            Content="{Binding OptimizeButtonLabel}"
                            HotKey="Ctrl+Return"
                            ToolTip.Tip="Run the batch (Ctrl+Enter)"
                            IsVisible="{Binding !IsRunning}"
                            IsEnabled="{Binding CanOptimize}"
                            Command="{Binding OptimizeCommand}" />
                    <Button Classes="primary"
                            Content="{Binding CancelButtonLabel}"
                            IsVisible="{Binding IsRunning}"
                            IsEnabled="{Binding CanCancel}"
                            Command="{Binding CancelRunCommand}" />

                    <Button x:Name="ThemeToggle"
                            Classes="icon"
                            Margin="4,0,0,0"
                            VerticalAlignment="Center"
                            Click="OnToggleThemeClick">
                        <PathIcon x:Name="ThemeToggleIcon" Width="15" Height="15" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== Three columns ==================== -->
        <Grid Grid.Row="2" ColumnDefinitions="300,Auto,*,Auto,340">

            <!-- ===== Left: asset queue ===== -->
            <Border Grid.Column="0"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource HairlineBrush}"
                    BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*,Auto">

                    <StackPanel Grid.Row="0" Margin="14,12,14,8" Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0"
                                       Classes="railHeading"
                                       Text="QUEUE"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Classes="caption"
                                       VerticalAlignment="Center"
                                       Text="{Binding ImageCount, StringFormat='{}{0} items'}" />
                        </Grid>

                        <!-- Filters earn their keep after a run with failures,
                             when the three bad files are buried among ninety-
                             seven good ones. -->
                        <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding HasPlan}">
                            <RadioButton Classes="chip"
                                         GroupName="QueueFilter"
                                         Content="All"
                                         IsChecked="{Binding SelectedQueueFilter,
                                                     Converter={x:Static vm:EnumMatchConverter.Instance},
                                                     ConverterParameter={x:Static vm:QueueFilter.All}}" />
                            <RadioButton Classes="chip"
                                         GroupName="QueueFilter"
                                         Content="{Binding OptimizedCount, StringFormat='Done ({0})'}"
                                         IsChecked="{Binding SelectedQueueFilter,
                                                     Converter={x:Static vm:EnumMatchConverter.Instance},
                                                     ConverterParameter={x:Static vm:QueueFilter.Optimized}}" />
                            <RadioButton Classes="chip"
                                         GroupName="QueueFilter"
                                         Content="{Binding FailedItemCount, StringFormat='Failed ({0})'}"
                                         IsChecked="{Binding SelectedQueueFilter,
                                                     Converter={x:Static vm:EnumMatchConverter.Instance},
                                                     ConverterParameter={x:Static vm:QueueFilter.Failed}}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Selecting a row drives the viewport and the statistics
                         overlay; everything else on screen is whole-batch. -->
                    <ListBox Grid.Row="1"
                             x:Name="QueueList"
                             Classes="queue"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="6,0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemsSource="{Binding VisibleQueueRows}"
                             SelectedItem="{Binding SelectedPlanItem}">

                        <!-- Right-clicking a row acts on that row, so the menu
                             is bound to the window's view model rather than the
                             row's, and every command works off SelectedPlanItem.
                             OnQueueRightClick selects the row under the cursor
                             first, so right-click-without-left-click behaves. -->
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Remove From Queue"
                                          Command="{Binding RemoveSelectedCommand}" />
                                <Separator />
                                <MenuItem Header="Show in File Manager"
                                          Command="{Binding ShowSelectedInFolderCommand}" />
                            </ContextMenu>
                        </ListBox.ContextMenu>

                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PlanItemRow">
                                <!-- The status column is a fixed width whether or
                                     not a mark is showing, so the size figures
                                     line up down the rail instead of jittering
                                     left as each file finishes. -->
                                <Grid ColumnDefinitions="Auto,*,Auto,14"
                                      Height="52"
                                      Margin="0,1"
                                      ToolTip.Tip="{Binding SourcePath}">

                                    <!-- The badge is the fallback, not the
                                         placeholder: AVIF and RAW have no
                                         platform decoder, so their rows keep it
                                         for good. -->
                                    <Panel Grid.Column="0" Width="36" Height="36" VerticalAlignment="Center">
                                        <Border CornerRadius="7"
                                                Background="{DynamicResource AccentSoftBrush}">
                                            <TextBlock Text="{Binding OutputFormatName}"
                                                       FontSize="9"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                        <Border CornerRadius="7" ClipToBounds="True">
                                            <Image Source="{Binding Thumbnail}" Stretch="UniformToFill" />
                                        </Border>
                                    </Panel>

                                    <StackPanel Grid.Column="1"
                                                Margin="11,0,8,0"
                                                VerticalAlignment="Center"
                                                Spacing="2">
                                        <TextBlock Text="{Binding FileName}"
                                                   Classes="queueName"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding FormatSummary}"
                                                   Classes="queueMeta"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding SizeText}"
                                               Classes="queueMeta"
                                               VerticalAlignment="Center"
                                               TextAlignment="Right" />

                                    <Panel Grid.Column="3" VerticalAlignment="Center">
                                        <TextBlock Text="✓"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource SuccessBrush}"
                                                   IsVisible="{Binding IsOptimized}" />
                                        <!-- Kept as-is: encoded fine, but no
                                             smaller, so the original stands. -->
                                        <TextBlock Text="="
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   IsVisible="{Binding IsUnchanged}"
                                                   ToolTip.Tip="Already as small as this quality setting can make it, so the original was kept." />
                                        <!-- Converted as asked, and bigger for
                                             it. Emphatically not a green tick. -->
                                        <TextBlock Text="▲"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource DangerBrush}"
                                                   IsVisible="{Binding IsInflated}"
                                                   ToolTip.Tip="Larger than the original. The conversion you asked for cannot compress this image." />
                                        <TextBlock Text="!"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{DynamicResource DangerBrush}"
                                                   IsVisible="{Binding IsFailed}"
                                                   ToolTip.Tip="{Binding ErrorMessage}" />
                                    </Panel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="2"
                               Classes="caption"
                               Margin="14,8"
                               IsVisible="{Binding HasMoreItems}"
                               Text="{Binding MoreItemsNote}" />
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4"
                          Background="Transparent"
                          ResizeDirection="Columns" />

            <!-- ===== Center: viewport ===== -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*,Auto">

                <!--
                  Which image, and how you are looking at it. The view controls
                  live in the header rather than floating over the photo: they are
                  chrome for the viewport, they are needed at every zoom level, and
                  a bar that only appears on hover is a bar nobody finds.
                -->
                <Border Grid.Row="0"
                        Padding="16,8,12,8"
                        IsVisible="{Binding HasPreview}"
                        BorderBrush="{DynamicResource HairlineBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding PreviewFileName}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding PreviewDimensionsText}" Classes="caption" />
                        </StackPanel>

                        <!-- Zoom is a scale, so it reads out as one: the − and +
                             bracket the figure they change, and the figure is a
                             fixed-width chip so it does not breathe from 9% to
                             100% and shove the buttons around. -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="4"
                                    VerticalAlignment="Center">
                            <Button Classes="icon"
                                    HotKey="Ctrl+OemMinus"
                                    ToolTip.Tip="Zoom out (Ctrl+−)"
                                    Click="OnZoomOutClick">
                                <PathIcon Data="{StaticResource IconMinus}" />
                            </Button>

                            <Border Classes="valueChip">
                                <TextBlock Text="{Binding #Compare.ZoomText}" />
                            </Border>

                            <Button Classes="icon"
                                    HotKey="Ctrl+OemPlus"
                                    ToolTip.Tip="Zoom in (Ctrl++)"
                                    Click="OnZoomInClick">
                                <PathIcon Data="{StaticResource IconPlus}" />
                            </Button>

                            <Rectangle Classes="vRule" Margin="6,6" />

                            <!-- Fit greys out once the view is already fitted:
                                 a button that does nothing should say so. -->
                            <Button Classes="ghost"
                                    Content="Fit"
                                    Padding="10,5"
                                    HotKey="Ctrl+D0"
                                    IsEnabled="{Binding !#Compare.IsFitToWindow}"
                                    ToolTip.Tip="Fit the whole image in the window (Ctrl+0)"
                                    Click="OnFitToWindowClick" />
                            <Button Classes="ghost"
                                    Content="100%"
                                    Padding="10,5"
                                    HotKey="Ctrl+D1"
                                    ToolTip.Tip="Actual size, one image pixel per screen pixel (Ctrl+1). The only honest way to judge compression artefacts."
                                    Click="OnActualSizeClick" />
                            <Button Classes="ghost"
                                    Content="Reset"
                                    Padding="10,5"
                                    ToolTip.Tip="Re-centre the image and put the divider back in the middle"
                                    Click="OnResetViewClick" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!--
                  The comparison surface. One custom-rendered control (CompareView)
                  draws both bitmaps into the same destination rect, wipes between
                  them with a render-time clip, and owns the zoom and the pan. See
                  CompareView.cs for why this is not two Images in a Border: the
                  short version is that expressing a wipe as layout re-fits the
                  image on every pointer move, and two images that each fit
                  themselves do not land in the same place.
                -->
                <Border Grid.Row="1" Classes="pane" Margin="16">
                    <Panel>
                        <Panel.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Remove From Queue"
                                          Command="{Binding RemoveSelectedCommand}" />
                                <MenuItem Header="Show in File Manager"
                                          Command="{Binding ShowSelectedInFolderCommand}" />
                            </ContextMenu>
                        </Panel.ContextMenu>

                        <views:CompareView x:Name="Compare"
                                           IsVisible="{Binding HasPreview}"
                                           BeforeImage="{Binding OriginalPreviewImage}"
                                           AfterImage="{Binding OutputPreviewImage}"
                                           DividerBrush="{DynamicResource DividerLineBrush}"
                                           HandleBackground="{DynamicResource OverlayStrongBrush}"
                                           HandleBorderBrush="{DynamicResource HairlineBrush}"
                                           HandleForeground="{DynamicResource AccentBrush}" />

                        <!-- Floating pane labels -->
                        <Border Classes="overlayChip"
                                IsVisible="{Binding HasPreview}"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                Margin="12">
                            <TextBlock Classes="overlayLabel" Text="ORIGINAL" />
                        </Border>
                        <!-- Not always "OPTIMIZED": see PreviewAfterLabel. -->
                        <Border Classes="overlayChip"
                                IsVisible="{Binding HasPreview}"
                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                Margin="12">
                            <TextBlock Classes="overlayLabel"
                                       Classes.larger="{Binding PreviewSavingsIsLarger}"
                                       Text="{Binding PreviewAfterLabel}" />
                        </Border>

                        <!-- Statistics, docked to the bottom of the image it
                             describes. PreviewAccuracyNote says whether these
                             bytes were measured or estimated — ADR-0006 forbids
                             conflating the two, so it gets its own line rather
                             than being crammed in as a column heading, where it
                             used to knock the three figures out of alignment. -->
                        <StackPanel IsVisible="{Binding HasPreview}"
                                    HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                    Margin="16">

                            <Border Classes="overlayCard" HorizontalAlignment="Center">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="18,12,18,11">
                                        <StackPanel MinWidth="88" Spacing="3">
                                            <TextBlock Classes="overlayLabel" Text="ORIGINAL" />
                                            <TextBlock Classes="overlayValue"
                                                       Text="{Binding PreviewOriginalSizeText}" />
                                        </StackPanel>

                                        <Rectangle Classes="vRule" Margin="14,2" />

                                        <StackPanel MinWidth="88" Spacing="3">
                                            <TextBlock Classes="overlayLabel" Text="OPTIMIZED" />
                                            <TextBlock Classes="overlayValue"
                                                       Text="{Binding PreviewOutputSizeText}" />
                                        </StackPanel>

                                        <Rectangle Classes="vRule" Margin="14,2" />

                                        <StackPanel MinWidth="108" Spacing="3">
                                            <TextBlock Classes="overlayLabel" Text="SIZE DIFFERENCE" />
                                            <!-- Green only when it is actually
                                                 smaller. A GIF conversion can
                                                 double a photo, and ADR-0007 lets
                                                 it, so this figure can legitimately
                                                 read "95% larger" — which must not
                                                 arrive in the success colour. -->
                                            <TextBlock Classes="savings"
                                                       Classes.larger="{Binding PreviewSavingsIsLarger}"
                                                       Text="{Binding PreviewSavingsText}" />
                                        </StackPanel>
                                    </StackPanel>

                                    <Border BorderBrush="{DynamicResource HairlineBrush}"
                                            BorderThickness="0,1,0,0"
                                            Padding="18,7">
                                        <TextBlock Classes="caption"
                                                   HorizontalAlignment="Center"
                                                   Text="{Binding PreviewAccuracyNote}" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Classes="overlayChip"
                                IsVisible="{Binding IsPreviewBusy}"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="16">
                            <TextBlock Text="Encoding…" Classes="caption" />
                        </Border>

                        <!-- Encode succeeded, but no decoder here can show it -->
                        <Border Classes="overlayCard"
                                IsVisible="{Binding HasOutputPreviewUnavailableNote}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                MaxWidth="360" Padding="16,12">
                            <TextBlock Text="{Binding OutputPreviewUnavailableNote}"
                                       Classes="caption"
                                       TextWrapping="Wrap" TextAlignment="Center" />
                        </Border>

                        <!-- Empty state / drop target -->
                        <Border x:Name="DropZoneInner"
                                IsVisible="{Binding ShowDropZone}"
                                Background="Transparent"
                                CornerRadius="10"
                                PointerPressed="OnDropZonePressed">
                            <Panel>
                                <shapes:Rectangle x:Name="DropOutline"
                                                  Margin="28"
                                                  RadiusX="12" RadiusY="12"
                                                  Stroke="{DynamicResource HairlineBrush}"
                                                  StrokeThickness="2"
                                                  StrokeDashArray="6,4"
                                                  Fill="Transparent" />
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="8">
                                    <TextBlock Text="Drop images here"
                                               Classes="h2"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding SupportedInputSummary}"
                                               Classes="caption"
                                               MaxWidth="420"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center" />
                                    <Button Classes="subtle"
                                            Content="Choose files…"
                                            HorizontalAlignment="Center"
                                            Margin="0,8,0,0"
                                            Click="OnAddFilesClick" />
                                </StackPanel>
                            </Panel>
                        </Border>

                        <Border IsVisible="{Binding IsPlanning}"
                                Background="{DynamicResource PreviewBackdropBrush}">
                            <TextBlock Text="Reading files…"
                                       Classes="body secondary"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <!-- Summary sits over the viewport rather than owning a
                             screen, so the queue and inspector stay visible and
                             a second pass needs no back-navigation. -->
                        <Border IsVisible="{Binding HasSummary}"
                                Background="{DynamicResource PreviewBackdropBrush}">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        MaxWidth="480"
                                        Spacing="10">
                                <TextBlock Text="{Binding SummaryHeadline}"
                                           Classes="h2"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center" />

                                <!-- SummarySavings is now always a short figure
                                     ("58% smaller", "No change"), so it fits the
                                     36px stat. Wrapping stays as a backstop. -->
                                <TextBlock Text="{Binding SummarySavings}"
                                           Classes="stat"
                                           Classes.larger="{Binding SummaryOutputIsLarger}"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center" />

                                <!-- The sentence that used to be crammed into
                                     the stat, and clipped. -->
                                <TextBlock Text="{Binding SummarySavingsNote}"
                                           IsVisible="{Binding HasSummarySavingsNote}"
                                           Classes="caption"
                                           MaxWidth="420"
                                           Margin="0,2,0,6"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center" />

                                <TextBlock Classes="caption"
                                           HorizontalAlignment="Center"
                                           Text="{Binding SummaryOriginalSizeText, StringFormat='{}{0} before'}" />
                                <TextBlock Classes="caption"
                                           HorizontalAlignment="Center"
                                           Text="{Binding SummaryFinalSizeText, StringFormat='{}{0} after'}" />

                                <ItemsControl ItemsSource="{Binding FailureMessages}"
                                              IsVisible="{Binding HasFailures}"
                                              Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <TextBlock Text="{Binding}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource DangerBrush}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            HorizontalAlignment="Center"
                                            Margin="0,8,0,0">
                                    <Button Classes="subtle"
                                            Content="Open output folder"
                                            Click="OnOpenOutputFolderClick" />
                                    <Button Classes="primary"
                                            Content="Start over"
                                            Command="{Binding StartOverCommand}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Panel>
                </Border>

                <!-- Batch-level warnings: fallbacks, renames, skips -->
                <StackPanel Grid.Row="2" Margin="16,0,16,12" Spacing="3">
                    <TextBlock Classes="caption"
                               IsVisible="{Binding HasFormatFallbacks}"
                               Text="{Binding FallbackSummary}"
                               TextWrapping="Wrap" />
                    <TextBlock Classes="caption"
                               IsVisible="{Binding HasRenames}"
                               Text="{Binding RenamedSummary}"
                               TextWrapping="Wrap" />
                    <ItemsControl ItemsSource="{Binding SkippedGroups}"
                                  IsVisible="{Binding HasSkippedFiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{Binding}" Classes="caption" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>

            <GridSplitter Grid.Column="3" Width="4"
                          Background="Transparent"
                          ResizeDirection="Columns" />

            <!-- ===== Right: inspector ===== -->
            <Border Grid.Column="4"
                    Background="{DynamicResource CardBrush}"
                    BorderBrush="{DynamicResource HairlineBrush}"
                    BorderThickness="1,0,0,0">
                <ScrollViewer>
                    <StackPanel Margin="14" Spacing="6">

                        <TextBlock Classes="railHeading" Text="INSPECTOR" Margin="2,4,2,6" />

                        <Expander Header="Format" IsExpanded="True">
                            <StackPanel Spacing="8" Margin="0,6,0,2">
                                <ComboBox HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding AvailableTargetFormats}"
                                          SelectedItem="{Binding SelectedTargetFormatOption}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:MainWindowViewModel+FormatOption">
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <!-- The eleven-format "Supports JPEG, PNG, WebP,
                                     …" blob used to wrap to four lines here and
                                     bury the one control that matters. It is a
                                     reference list, so it lives behind the Help
                                     dialog that already renders it from the
                                     registry — count here, list on demand. -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Classes="caption"
                                               VerticalAlignment="Center"
                                               Text="{Binding SupportedInputCountSummary}" />
                                    <Button Grid.Column="1"
                                            Classes="ghost"
                                            Content="View all"
                                            Padding="8,3"
                                            FontSize="11"
                                            Click="OnSupportedFormatsClick" />
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <Expander Header="Quality" IsExpanded="True">
                            <!--
                              The value and its name never share a line's worth of
                              space and never move: the name sits in a left column
                              that is free to ellipsise, the number in a fixed-width
                              chip on the right. They used to be two TextBlocks in a
                              *,Auto grid, so "Near-original" grew until it collided
                              with the digits.
                            -->
                            <StackPanel Spacing="8" Margin="0,6,0,2">
                                <!--
                                  The whole dial goes dead for a target that has
                                  no quality knob (GIF, PNG, BMP, TIFF). It used
                                  to stay live and do nothing, which is how a user
                                  ends up dragging quality to 8% to shrink a GIF
                                  batch and watching it grow anyway.
                                -->
                                <TextBlock Classes="caption"
                                           IsVisible="{Binding !QualityAppliesToTarget}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource DangerBrush}"
                                           Text="{Binding QualityIgnoredNote}" />

                                <!--
                                  The dial is hidden, not merely greyed, for a
                                  target that ignores it. A disabled slider still
                                  printed "Preset: Near-original", "95%" and a
                                  sentence about how much compression to expect,
                                  directly beneath a warning that none of it
                                  applies. Two of those three things were simply
                                  false for GIF. Say the one true thing instead.
                                -->
                                <Grid ColumnDefinitions="*,Auto"
                                      IsVisible="{Binding QualityAppliesToTarget}">
                                    <TextBlock Grid.Column="0"
                                               Classes="caption"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding QualityLabel, StringFormat='Preset: {0}'}" />
                                    <Border Grid.Column="1" Classes="valueChip">
                                        <TextBlock Text="{Binding Quality, StringFormat='{}{0}%'}" />
                                    </Border>
                                </Grid>

                                <StackPanel Spacing="0" IsVisible="{Binding QualityAppliesToTarget}">
                                    <Slider Minimum="1" Maximum="100"
                                            TickFrequency="1"
                                            IsSnapToTickEnabled="True"
                                            Value="{Binding Quality}" />

                                    <UniformGrid Columns="9" Margin="9,0,9,5">
                                        <Rectangle Classes="tick" />
                                        <Rectangle Classes="tick" />
                                        <Rectangle Classes="tick" />
                                        <Rectangle Classes="tick" />
                                        <Rectangle Classes="tick" />
                                        <Rectangle Classes="tick" />
                                        <Rectangle Classes="tick" />
                                        <Rectangle Classes="tick" />
                                        <Rectangle Classes="tick" />
                                    </UniformGrid>

                                    <!--
                                      One line that moves with the slider, in
                                      place of a fixed three-column scale
                                      ("Smaller file | Balanced | Near-original").
                                      The scale said the same thing at every
                                      value, so it never told the user where they
                                      were, and in a 340px rail its three labels
                                      collided into one unreadable run of words.
                                    -->
                                    <TextBlock Classes="scaleLabel"
                                               Margin="0,4,0,0"
                                               MinHeight="28"
                                               TextWrapping="Wrap"
                                               Text="{Binding QualityDescription}" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <Expander Header="Resize" IsExpanded="False">
                            <StackPanel Spacing="8" Margin="0,6,0,2">
                                <CheckBox Content="Limit longest edge"
                                          IsChecked="{Binding ResizeEnabled}" />
                                <NumericUpDown Minimum="16" Maximum="20000"
                                               Increment="64"
                                               FormatString="0"
                                               IsEnabled="{Binding ResizeEnabled}"
                                               Value="{Binding ResizeMaxDimensionPixels}" />
                                <TextBlock Classes="caption"
                                           TextWrapping="Wrap"
                                           Text="Images smaller than this keep their original size." />
                            </StackPanel>
                        </Expander>

                        <Expander Header="Metadata" IsExpanded="False">
                            <StackPanel Spacing="8" Margin="0,6,0,2">
                                <CheckBox Content="Strip metadata"
                                          IsChecked="{Binding StripMetadata}" />
                                <TextBlock Classes="caption"
                                           TextWrapping="Wrap"
                                           Text="Removes EXIF, GPS and colour-profile tags." />
                            </StackPanel>
                        </Expander>

                        <Expander Header="Output" IsExpanded="True">
                            <StackPanel Spacing="8" Margin="0,6,0,2">
                                <CheckBox Content="Overwrite originals"
                                          IsChecked="{Binding OverwriteOriginals}" />
                                <StackPanel Spacing="7" IsVisible="{Binding ShowOutputFolderControl}">
                                    <!-- One line, ellipsised from the left so the
                                         folder name survives and the drive letter
                                         is what gets cut. A wrapped absolute path
                                         was taking three lines of the rail. -->
                                    <Border Classes="pathChip" ToolTip.Tip="{Binding OutputDirectory}">
                                        <TextBlock Text="{Binding OutputDirectory}"
                                                   Classes="caption"
                                                   TextTrimming="LeadingCharacterEllipsis" />
                                    </Border>
                                    <Button Classes="subtle"
                                            Content="Change folder…"
                                            HorizontalContentAlignment="Center"
                                            HorizontalAlignment="Stretch"
                                            Click="OnChangeOutputFolderClick" />
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <!--
                          The batch is going to get bigger. Said in words, in
                          bytes, above the estimate rather than inside it — and
                          repeated as a blocking confirmation when Optimize is
                          pressed, because a banner in a rail is still something
                          a user can scroll past.
                        -->
                        <Border Classes="warning"
                                Margin="0,8,0,0"
                                IsVisible="{Binding HasInflationWarning}">
                            <StackPanel Spacing="4">
                                <TextBlock Text="This will not save space"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource DangerBrush}" />
                                <TextBlock Text="{Binding InflationWarningText}" Classes="caption" />
                            </StackPanel>
                        </Border>

                        <!-- Whole-batch estimate. Distinct from the viewport
                             overlay, which reports one exactly-encoded image. -->
                        <Border Classes="reservedSlot" Margin="0,8,0,0" IsVisible="{Binding HasPlan}">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="railHeading" Text="BATCH SIZE" />
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Text="Original" Classes="caption" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding OriginalSizeText}"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               TextAlignment="Right" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <!-- The row's own label says which of the two
                                         numbers this is: a guess from file sizes,
                                         or bytes an encoder actually produced. -->
                                    <TextBlock Grid.Column="0"
                                               Classes="caption"
                                               Text="Estimated"
                                               IsVisible="{Binding !HasMeasuredBatch}" />
                                    <TextBlock Grid.Column="0"
                                               Classes="caption"
                                               Text="Measured"
                                               IsVisible="{Binding HasMeasuredBatch}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding EstimatedSizeText}"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               TextAlignment="Right" />
                                </Grid>
                                <Border BorderBrush="{DynamicResource HairlineBrush}"
                                        BorderThickness="0,1,0,0"
                                        Padding="0,6,0,0">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <TextBlock Grid.Column="0"
                                                   Text="Total reduction"
                                                   Classes="caption"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Classes="savings"
                                                   Classes.larger="{Binding EstimatedOutputIsLarger}"
                                                   Text="{Binding EstimatedSavingsSummary}"
                                                   FontSize="13"
                                                   TextAlignment="Right" />
                                    </Grid>
                                </Border>

                                <!--
                                  Recalculate encodes a spread of the real images
                                  at the current settings and projects what it
                                  measures across the batch. The figures above are
                                  otherwise a heuristic over file sizes, which was
                                  off by 2.1× on a GIF batch, and no colour on a
                                  wrong number makes it right.
                                -->
                                <TextBlock Classes="caption"
                                           Margin="0,2,0,0"
                                           TextWrapping="Wrap"
                                           Text="{Binding BatchAccuracyNote}" />

                                <Button Classes="subtle"
                                        Content="Recalculate"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        IsVisible="{Binding !IsMeasuringBatch}"
                                        Command="{Binding MeasureBatchCommand}"
                                        ToolTip.Tip="Encode a sample of these images at the current quality and measure the real result" />
                                <Button Classes="subtle"
                                        Content="Measuring…"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        IsEnabled="False"
                                        IsVisible="{Binding IsMeasuringBatch}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ==================== Status bar ==================== -->
        <Border Grid.Row="3"
                Background="{DynamicResource StatusBarBrush}"
                BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,6">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusBarText}"
                           Classes="caption"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Column="1"
                           Margin="14,0"
                           Classes="caption"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           IsVisible="{Binding HasStatusMessage}"
                           Foreground="{DynamicResource DangerBrush}"
                           Text="{Binding StatusMessage}" />

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="12"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsRunning}">
                    <TextBlock Classes="caption"
                               MaxWidth="280"
                               TextTrimming="CharacterEllipsis"
                               Text="{Binding ProgressLabel}" />
                    <TextBlock Classes="caption"
                               IsVisible="{Binding HasRunMetrics}"
                               Text="{Binding ThroughputText}" />
                    <TextBlock Classes="caption"
                               IsVisible="{Binding HasRunMetrics}"
                               Text="{Binding EtaText, StringFormat='{}{0} left'}" />
                </StackPanel>

                <ProgressBar Grid.Column="3"
                             Classes="slim"
                             Width="200"
                             VerticalAlignment="Center"
                             IsVisible="{Binding IsRunning}"
                             Minimum="0" Maximum="100"
                             Value="{Binding ProgressPercent}" />
            </Grid>
        </Border>
    </Grid>
</Window>

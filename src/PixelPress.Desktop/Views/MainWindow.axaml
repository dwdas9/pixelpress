<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PixelPress.Desktop.ViewModels"
        x:Class="PixelPress.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="PixelPress"
        Width="820" Height="680"
        MinWidth="660" MinHeight="540"
        Background="{DynamicResource CanvasBrush}"
        WindowStartupLocation="CenterScreen">

    <!--
      Three persistent zones: header, content stage (the five workflow
      states, one visible at a time), and status bar. All visual
      language lives in Styles/AppStyles.axaml; theming is instant via
      DynamicResource + theme dictionaries.
    -->
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ============ Header ============ -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="32,20,32,16">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                <Border CornerRadius="10" Width="38" Height="38">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#6366F1" Offset="0" />
                            <GradientStop Color="#8B5CF6" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="⬇" FontSize="19" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="PixelPress" FontSize="17" FontWeight="Bold" />
                    <TextBlock Classes="caption" Text="Optimize images — private, offline" />
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="2" Classes="subtle"
                    Name="ThemeToggle"
                    Content="🌙  Dark"
                    Click="OnToggleThemeClick"
                    VerticalAlignment="Center" />
        </Grid>

        <!-- ============ Content stage ============ -->
        <Grid Grid.Row="1" Margin="32,0,32,20">

            <!-- State 1: awaiting input -->
            <Grid RowDefinitions="*,Auto" IsVisible="{Binding ShowDropZone}">

                <Border Grid.Row="0" Classes="card" Padding="12">
                    <Border Name="DropZoneInner"
                            DragDrop.AllowDrop="True"
                            Background="Transparent"
                            CornerRadius="12"
                            Cursor="Hand"
                            PointerPressed="OnDropZonePressed">
                        <Grid>
                            <Rectangle Name="DropOutline"
                                       Stroke="{DynamicResource HairlineBrush}"
                                       StrokeThickness="2"
                                       StrokeDashArray="6,4"
                                       RadiusX="12" RadiusY="12"
                                       Fill="Transparent" />
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Spacing="14" Margin="24">
                                <Border Background="{DynamicResource AccentSoftBrush}"
                                        CornerRadius="32" Width="64" Height="64"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="⬆" FontSize="26"
                                               Foreground="{DynamicResource AccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Classes="h2"
                                           Text="Drop images or folders here"
                                           HorizontalAlignment="Center" />
                                <TextBlock Classes="body secondary"
                                           Text="Shrink photos and screenshots without losing what matters — everything stays on your computer."
                                           TextWrapping="Wrap" MaxWidth="420"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center" />
                                <StackPanel Orientation="Horizontal" Spacing="8"
                                            HorizontalAlignment="Center">
                                    <Button Classes="subtle" Content="Browse files…"
                                            Click="OnDropZonePressedButton" />
                                    <Button Classes="subtle" Content="Choose a folder…"
                                            Click="OnBrowseFolderClick" />
                                </StackPanel>
                                <TextBlock Classes="caption"
                                           Text="{Binding SupportedInputSummary}"
                                           TextWrapping="Wrap" MaxWidth="440"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Border>

                <StackPanel Grid.Row="1" Margin="0,18,0,0" Spacing="10">
                    <ListBox Classes="presets"
                             ItemsSource="{Binding AvailablePresets}"
                             SelectedItem="{Binding SelectedPreset}"
                             HorizontalAlignment="Center">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="12" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="presetCard" Width="184">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold" FontSize="14" />
                                        <TextBlock Text="{Binding Description}"
                                                   Classes="caption"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock Classes="caption"
                               Foreground="{DynamicResource DangerBrush}"
                               Text="{Binding StatusMessage}"
                               HorizontalAlignment="Center"
                               IsVisible="{Binding HasStatusMessage}" />
                </StackPanel>
            </Grid>

            <!-- State 2: planning -->
            <StackPanel IsVisible="{Binding IsPlanning}"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Spacing="14">
                <ProgressBar Classes="slim" IsIndeterminate="True" Width="220" />
                <TextBlock Classes="body secondary"
                           Text="Looking through your files…"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- State 3: plan preview -->
            <Grid RowDefinitions="Auto,Auto,*,Auto" IsVisible="{Binding HasPlan}">

                <Border Grid.Row="0" Classes="card" Padding="28,22" Margin="0,0,0,14">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Classes="h1" Text="{Binding OptimizeButtonLabel}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Classes="body secondary" Text="{Binding OriginalSizeText}" />
                                <TextBlock Classes="body secondary" Text="→" />
                                <TextBlock Classes="body" FontWeight="SemiBold" Text="{Binding EstimatedSizeText}" />
                                <TextBlock Classes="body"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           FontWeight="SemiBold"
                                           Text="{Binding EstimatedSavingsSummary}" />
                                <TextBlock Classes="caption" Text="(estimated)" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Classes="subtle"
                                Content="Change output folder…"
                                Click="OnChangeOutputFolderClick"
                                IsVisible="{Binding ShowOutputFolderControl}"
                                VerticalAlignment="Top" />
                    </Grid>
                </Border>

                <!-- Advanced options -->
                <Border Grid.Row="1" Classes="card" Padding="16" Margin="0,0,0,14">
                    <StackPanel Spacing="14">
                        <Button Classes="ghost" Padding="4"
                                Content="{Binding AdvancedPanelToggleLabel}"
                                Command="{Binding ToggleAdvancedPanelCommand}"
                                HorizontalAlignment="Left" />

                        <StackPanel Spacing="16" IsVisible="{Binding IsAdvancedPanelExpanded}">

                            <StackPanel Spacing="8">
                                <TextBlock Classes="caption" FontWeight="SemiBold" Text="CONVERT TO" />
                                <ListBox Classes="presets"
                                         ItemsSource="{Binding AvailableTargetFormats}"
                                         SelectedItem="{Binding SelectedTargetFormatOption}">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Classes="presetCard" Padding="12,8">
                                                <TextBlock Text="{Binding DisplayName}" FontSize="13" />
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>

                            <Border Height="1" Background="{DynamicResource HairlineBrush}" />

                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <CheckBox Content="Resize large images to fit within"
                                          IsChecked="{Binding ResizeEnabled}" />
                                <NumericUpDown Value="{Binding ResizeMaxDimensionPixels}"
                                               Minimum="1" Maximum="20000" Increment="64"
                                               FormatString="0" Width="130"
                                               IsEnabled="{Binding ResizeEnabled}" />
                                <TextBlock Classes="body secondary" Text="px" VerticalAlignment="Center" />
                            </StackPanel>

                            <CheckBox Content="Remove EXIF, location and camera data from output files"
                                      IsChecked="{Binding StripMetadata}" />

                            <StackPanel Spacing="2">
                                <CheckBox Content="Overwrite original files instead of writing to a new folder"
                                          IsChecked="{Binding OverwriteOriginals}" />
                                <TextBlock Classes="caption" Margin="26,0,0,0"
                                           Foreground="{DynamicResource DangerBrush}"
                                           Text="Replaces original files — cannot be undone."
                                           IsVisible="{Binding OverwriteOriginals}" />
                            </StackPanel>

                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Classes="card" Padding="16">
                    <Grid RowDefinitions="Auto,*,Auto">
                        <Grid Grid.Row="0" ColumnDefinitions="*,140,90" Margin="12,4,12,8">
                            <TextBlock Grid.Column="0" Classes="caption" Text="NAME" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Classes="caption" Text="FORMAT" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Classes="caption" Text="SIZE" FontWeight="SemiBold"
                                       TextAlignment="Right" />
                        </Grid>
                        <ScrollViewer Grid.Row="1">
                            <StackPanel>
                                <ItemsControl ItemsSource="{Binding PlanItemRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Classes="fileRow">
                                                <Grid ColumnDefinitions="*,140,90">
                                                    <TextBlock Grid.Column="0" Classes="body"
                                                               Text="{Binding FileName}"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Column="1" Classes="body secondary"
                                                               Text="{Binding FormatSummary}" />
                                                    <TextBlock Grid.Column="2" Classes="body secondary"
                                                               Text="{Binding SizeText}"
                                                               TextAlignment="Right" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Classes="caption" Margin="12,6,0,4"
                                           Text="{Binding MoreItemsNote}"
                                           IsVisible="{Binding HasMoreItems}" />
                            </StackPanel>
                        </ScrollViewer>
                        <StackPanel Grid.Row="2" Spacing="4" Margin="12,10,12,2">
                            <TextBlock Classes="caption"
                                       Text="{Binding FallbackSummary}"
                                       IsVisible="{Binding HasFormatFallbacks}" />
                            <TextBlock Classes="caption"
                                       Text="{Binding RenamedSummary}"
                                       IsVisible="{Binding HasRenames}" />
                            <ItemsControl ItemsSource="{Binding SkippedGroups}"
                                          IsVisible="{Binding HasSkippedFiles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Classes="caption" Text="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="3" Margin="0,16,0,0" Spacing="8">
                    <Button Classes="primary"
                            Content="{Binding OptimizeButtonLabel}"
                            Command="{Binding OptimizeCommand}"
                            IsEnabled="{Binding CanOptimize}"
                            HorizontalAlignment="Stretch" />
                    <Button Classes="ghost"
                            Content="Start Over"
                            Command="{Binding StartOverCommand}"
                            HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- State 4: running -->
            <Grid RowDefinitions="*,Auto" IsVisible="{Binding IsRunning}">
                <Border Grid.Row="0" Classes="card" VerticalAlignment="Center">
                    <StackPanel Spacing="18">
                        <TextBlock Classes="h2" Text="Optimizing your images…"
                                   HorizontalAlignment="Center" />
                        <ProgressBar Classes="slim"
                                     Minimum="0" Maximum="100"
                                     Value="{Binding ProgressPercent}" />
                        <TextBlock Classes="caption"
                                   Text="{Binding ProgressLabel}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Button Grid.Row="1" Classes="ghost" Margin="0,16,0,0"
                        Content="{Binding CancelButtonLabel}"
                        Command="{Binding CancelRunCommand}"
                        IsEnabled="{Binding CanCancel}"
                        HorizontalAlignment="Center" />
            </Grid>

            <!-- State 5: completion summary -->
            <Grid RowDefinitions="*,Auto" IsVisible="{Binding HasSummary}">

                <Border Grid.Row="0" Classes="card" VerticalAlignment="Top">
                    <StackPanel Spacing="18">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="h1" Text="{Binding SummaryHeadline}" />
                            <TextBlock Classes="stat" Text="{Binding SummarySavings}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Classes="body secondary" Text="{Binding SummaryOriginalSizeText}" />
                                <TextBlock Classes="body secondary" Text="→" />
                                <TextBlock Classes="body" FontWeight="SemiBold" Text="{Binding SummaryFinalSizeText}" />
                            </StackPanel>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource HairlineBrush}" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Classes="body" FontWeight="Medium" Text="Saved to" />
                            <TextBlock Classes="body secondary"
                                       Text="{Binding OutputDirectory}"
                                       TextTrimming="CharacterEllipsis" MaxWidth="460" />
                        </StackPanel>

                        <StackPanel IsVisible="{Binding HasFailures}" Spacing="6">
                            <TextBlock Classes="body" FontWeight="Medium"
                                       Foreground="{DynamicResource DangerBrush}"
                                       Text="A few files couldn't be processed" />
                            <ItemsControl ItemsSource="{Binding FailureMessages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Classes="caption" Text="{Binding}" TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1" Margin="0,16,0,0" Spacing="8">
                    <Button Classes="primary"
                            Content="Open Output Folder"
                            Click="OnOpenOutputFolderClick"
                            HorizontalAlignment="Stretch" />
                    <Button Classes="ghost"
                            Content="Optimize More Images"
                            Command="{Binding StartOverCommand}"
                            HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>

        </Grid>

        <!-- ============ Status bar ============ -->
        <Border Grid.Row="2" Background="{DynamicResource StatusBarBrush}"
                Padding="32,8">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Classes="caption" Text="{Binding StatusBarText}" />
                <TextBlock Grid.Column="1" Classes="caption" Text="PixelPress 0.1" />
            </Grid>
        </Border>

    </Grid>
</Window>
